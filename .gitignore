# Miscellaneous
# Large ONNX runtime artifacts — downloaded + extracted at build time by
# src/CMakeLists.txt (file(DOWNLOAD)/ARCHIVE_EXTRACT), so never committed.
src/download/
src/lib/onnxruntime-android-*/
src/lib/onnxruntime-osx-*/
# (legacy paths, kept in case an older checkout used them)
ios/src/download/
ios/src/lib/onnxruntime-android-*/
example/assets/voices_flat.bin

# Scratch / one-off scripts
test_regex.dart
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/
